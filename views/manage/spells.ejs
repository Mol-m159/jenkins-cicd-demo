<%- include('../partials/header', { user: user, title: title }) %>

<div class="bg-white rounded-lg shadow">
    <div class="p-6 border-b flex justify-between items-center flex-wrap gap-4">
        <h1 class="text-2xl font-bold">📖 Управление заклинаниями</h1>
        <a href="/manage/spells/new" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition">
            + Новое заклинание
        </a>
    </div>
    
    <!-- Форма поиска и фильтров -->
    <div class="p-6 border-b bg-gray-50">
        <form method="get" action="/manage/spells" class="grid md:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm text-gray-600 mb-1">Поиск по названию</label>
                <input type="text" name="search" value="<%= search %>" placeholder="Название заклинания..."
                       class="w-full border rounded px-3 py-2">
            </div>
            <div>
                <label class="block text-sm text-gray-600 mb-1">Уровень</label>
                <select name="level" class="w-full border rounded px-3 py-2">
                    <option value="">Все уровни</option>
                    <% for(let i = 0; i <= 9; i++) { %>
                        <option value="<%= i %>" <%= level == i ? 'selected' : '' %>>
                            <%= i === 0 ? 'Заговор (0)' : i + ' уровень' %>
                        </option>
                    <% } %>
                </select>
            </div>
            <div>
                <label class="block text-sm text-gray-600 mb-1">Школа магии</label>
                <select name="school" class="w-full border rounded px-3 py-2">
                    <option value="">Все школы</option>
                    <% schools.forEach(s => { %>
                        <option value="<%= s %>" <%= school === s ? 'selected' : '' %>><%= s %></option>
                    <% }) %>
                </select>
            </div>
            <div class="flex items-end gap-2">
                <button type="submit" class="bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700">
                    🔍 Найти
                </button>
                <a href="/manage/spells" class="bg-gray-300 px-4 py-2 rounded hover:bg-gray-400">
                    Сбросить
                </a>
            </div>
        </form>
    </div>
    
    <div class="p-6">
        <div class="mb-2 text-sm text-gray-500">
            Найдено заклинаний: <%= spells.length %>
        </div>
        
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-2 text-left">Название</th>
                        <th class="px-4 py-2 text-center">Ур.</th>
                        <th class="px-4 py-2 text-center">Школа</th>
                        <th class="px-4 py-2 text-center">Дистанция</th>
                        <th class="px-4 py-2 text-center">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% spells.forEach(spell => { %>
                        <tr class="border-t hover:bg-gray-50">
                            <td class="px-4 py-3 font-medium">
                                <%= spell.name %>
                                <div class="text-xs text-gray-400 truncate max-w-md"><%= (spell.description || '').substring(0, 80) %>...</div>
                            </td>
                            <td class="px-4 py-3 text-center"><%= spell.level %></td>
                            <td class="px-4 py-3 text-center"><%= spell.school %></td>
                            <td class="px-4 py-3 text-center"><%= spell.range_spell %> ф.</td>
                            <td class="px-4 py-3 text-center whitespace-nowrap">
                                <a href="/manage/spells/edit/<%= encodeURIComponent(spell.name) %>" class="text-blue-600 mr-2 hover:text-blue-800">✏️</a>
                                <form method="post" action="/manage/spells/delete/<%= encodeURIComponent(spell.name) %>" class="inline" onsubmit="return confirm('Удалить заклинание «<%= spell.name %>»?')">
                                    <button type="submit" class="text-red-600 hover:text-red-800">🗑️</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        
        <% if (spells.length === 0) { %>
            <div class="text-center py-12">
                <p class="text-gray-500 mb-4">Заклинания не найдены</p>
                <a href="/manage/spells/new" class="text-purple-600 hover:underline">Создать первое заклинание →</a>
            </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>