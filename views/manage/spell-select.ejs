<%- include('../partials/header', { user: user, title: title }) %>

<div class="max-w-4xl mx-auto bg-white rounded-lg shadow p-6">
    <h1 class="text-2xl font-bold mb-2"><%= type === 'add' ? '📖 Добавление заклинаний' : '📝 Подготовка заклинаний' %></h1>
    <p class="text-gray-600 mb-6">
        Персонаж: <strong><%= character.name %></strong> 
        (<%= character.class %> <%= character.level %> уровень)
        <% if (type === 'ready' && maxPrepared > 0) { %>
            <span class="ml-4 text-sm">Можно подготовить до <strong><%= maxPrepared %></strong> заклинаний</span>
        <% } %>
    </p>
    
    <!-- Поиск и фильтры -->
    <div class="mb-6 p-4 bg-gray-50 rounded-lg">
        <div class="grid md:grid-cols-3 gap-4">
            <div>
                <label class="block text-sm text-gray-600 mb-1">🔍 Поиск по названию</label>
                <input type="text" id="spellSearch" placeholder="Название заклинания..." 
                       class="w-full border rounded px-3 py-2">
            </div>
            <div>
                <label class="block text-sm text-gray-600 mb-1">📊 Уровень</label>
                <select id="levelFilter" class="w-full border rounded px-3 py-2">
                    <option value="">Все уровни</option>
                    <option value="0">Заговоры (0)</option>
                    <option value="1">1 уровень</option>
                    <option value="2">2 уровень</option>
                    <option value="3">3 уровень</option>
                    <option value="4">4 уровень</option>
                    <option value="5">5 уровень</option>
                    <option value="6">6 уровень</option>
                    <option value="7">7 уровень</option>
                    <option value="8">8 уровень</option>
                    <option value="9">9 уровень</option>
                </select>
            </div>
            <div>
                <label class="block text-sm text-gray-600 mb-1">🎓 Школа</label>
                <select id="schoolFilter" class="w-full border rounded px-3 py-2">
                    <option value="">Все школы</option>
                    <option value="Ограждение">Ограждение</option>
                    <option value="Воплощение">Воплощение</option>
                    <option value="Вызов">Вызов</option>
                    <option value="Иллюзия">Иллюзия</option>
                    <option value="Некромантия">Некромантия</option>
                    <option value="Очарование">Очарование</option>
                    <option value="Превращение">Превращение</option>
                    <option value="Прорицание">Прорицание</option>
                </select>
            </div>
        </div>
        <div class="mt-3 text-right">
            <button type="button" onclick="resetFilters()" class="text-sm text-gray-500 hover:text-purple-600">Сбросить фильтры</button>
        </div>
    </div>
    
    <form method="post" action="<%= type === 'add' ? `/lc/fullSpellListPost/${user}/${camp_id}/${encodeURIComponent(character.name)}` : `/lc/readyPostSpellList/${user}/${camp_id}/${encodeURIComponent(character.name)}` %>">
        <div id="spellsContainer" class="space-y-4 mb-6">
            <!-- Заклинания будут отображаться здесь через JS -->
        </div>
        
        <div class="flex gap-3 justify-end mt-6">
            <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700">
                <%= type === 'add' ? 'Добавить выбранные' : 'Подготовить выбранные' %>
            </button>
            <a href="/lc/<%= user %>/<%= camp_id %>/<%= encodeURIComponent(character.name) %>" 
               class="bg-gray-300 px-6 py-2 rounded hover:bg-gray-400">
                Отмена
            </a>
        </div>
    </form>
</div>

<script>
    const spellsData = <%- JSON.stringify(spells) %>;
    const knownSpells = <%- JSON.stringify(knownSpells) %>;
    const type = '<%= type %>';
    
    function renderSpells() {
        const container = document.getElementById('spellsContainer');
        const searchTerm = document.getElementById('spellSearch').value.toLowerCase();
        const levelFilter = document.getElementById('levelFilter').value;
        const schoolFilter = document.getElementById('schoolFilter').value;
        
        const filtered = spellsData.filter(spell => {
            const matchSearch = searchTerm === '' || spell.name.toLowerCase().includes(searchTerm);
            const matchLevel = levelFilter === '' || spell.level == levelFilter;
            const matchSchool = schoolFilter === '' || spell.school === schoolFilter;
            return matchSearch && matchLevel && matchSchool;
        });
        
        if (filtered.length === 0) {
            container.innerHTML = '<div class="text-center py-8 text-gray-500">Заклинания не найдены</div>';
            return;
        }
        
        container.innerHTML = filtered.map(spell => {
            const isKnown = knownSpells && knownSpells.includes(spell.name);
            const isPrepared = type === 'ready' && spell.readiness == 1;
            const isDisabled = (type === 'add' && isKnown) ? 'disabled' : '';
            const isChecked = (type === 'add' && isKnown) || (type === 'ready' && isPrepared);
            
            return `
                <div class="border rounded-lg p-4 hover:bg-gray-50 transition">
                    <label class="flex items-start gap-3 cursor-pointer">
                        <input type="checkbox" name="spells" value="${spell.name.replace(/'/g, "\\'")}" 
                               class="mt-1" ${isChecked ? 'checked' : ''} ${isDisabled}>
                        <div class="flex-1">
                            <div class="font-bold text-lg">
                                ${spell.name}
                                <span class="text-sm text-gray-500 ml-2">уровень ${spell.level}</span>
                                <span class="text-xs bg-gray-100 px-2 py-0.5 rounded ml-2">${spell.school}</span>
                                ${type === 'add' && isKnown ? '<span class="text-xs bg-green-100 text-green-800 px-2 py-0.5 rounded ml-2">✓ Уже изучено</span>' : ''}
                            </div>
                            <div class="text-gray-700 mt-2">${(spell.description || '').replace(/\n/g, '<br>')}</div>
                        </div>
                    </label>
                </div>
            `;
        }).join('');
    }
    
    function resetFilters() {
        document.getElementById('spellSearch').value = '';
        document.getElementById('levelFilter').value = '';
        document.getElementById('schoolFilter').value = '';
        renderSpells();
    }
    
    document.getElementById('spellSearch').addEventListener('input', renderSpells);
    document.getElementById('levelFilter').addEventListener('change', renderSpells);
    document.getElementById('schoolFilter').addEventListener('change', renderSpells);
    
    renderSpells();
</script>

<%- include('../partials/footer') %>