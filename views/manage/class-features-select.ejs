<%- include('../partials/header', { user: user, title: title }) %>

<div class="max-w-4xl mx-auto bg-white rounded-lg shadow p-6">
    <h1 class="text-2xl font-bold mb-2">🌑 Выбор классовых настроек</h1>
    <p class="text-gray-600 mb-6">
        Персонаж: <strong><%= character.name %></strong> 
        (<%= character.class %> <%= character.level %> уровень)<br>
        Можно выбрать до <strong><%= maxFeatures %></strong> классовых настроек
    </p>
    
    <!-- Поиск и фильтр -->
    <div class="mb-6 p-4 bg-gray-50 rounded-lg">
        <div class="grid md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm text-gray-600 mb-1">🔍 Поиск по названию</label>
                <input type="text" id="featureSearch" placeholder="Название настройки..." 
                       class="w-full border rounded px-3 py-2">
            </div>
            <div>
                <label class="block text-sm text-gray-600 mb-1">📊 Минимальный уровень</label>
                <input type="number" id="levelFilter" min="1" max="<%= character.level %>" value="" 
                       placeholder="от 1 до <%= character.level %>" class="w-full border rounded px-3 py-2">
            </div>
        </div>
        <div class="mt-3 text-right">
            <button type="button" onclick="resetFilters()" class="text-sm text-gray-500 hover:text-purple-600">Сбросить фильтры</button>
        </div>
    </div>
    
    <form method="post" action="/lc/fullAppealsListPost/<%= user %>/<%= camp_id %>/<%= encodeURIComponent(character.name) %>">
        <div id="featuresContainer" class="space-y-4 mb-6">
            <!-- Настройки будут отображаться здесь через JS -->
        </div>
        
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-6">
            <p class="text-sm text-yellow-700">
                💡 <strong>Подсказка:</strong> Вы можете выбрать до <%= maxFeatures %> настроек.
                Если нужной настройки нет в списке, добавьте её в 
                <a href="/manage/class-features/<%= encodeURIComponent(character.class) %>" class="text-purple-600 hover:underline">библиотеку классовых настроек</a>.
            </p>
        </div>
        
        <div class="flex gap-3 justify-end">
            <button type="submit" class="bg-purple-600 text-white px-6 py-2 rounded hover:bg-purple-700 transition">
                Сохранить настройки
            </button>
            <a href="/lc/<%= user %>/<%= camp_id %>/<%= encodeURIComponent(character.name) %>" 
               class="bg-gray-300 px-6 py-2 rounded hover:bg-gray-400 transition">
                Отмена
            </a>
        </div>
    </form>
</div>

<script>
    const featuresData = <%- JSON.stringify(features) %>;
    const currentFeatures = <%- JSON.stringify(currentFeatures) %>;
    const maxFeatures = <%= maxFeatures %>;
    const characterLevel = <%= character.level %>;
    
    // Фильтруем настройки по уровню персонажа (показываем только те, что доступны по уровню)
    const availableFeatures = featuresData.filter(feature => feature.level <= characterLevel);
    
    function renderFeatures() {
        const container = document.getElementById('featuresContainer');
        const searchTerm = document.getElementById('featureSearch').value.toLowerCase();
        const levelFilter = parseInt(document.getElementById('levelFilter').value);
        
        const filtered = availableFeatures.filter(feature => {
            const matchSearch = searchTerm === '' || feature.name.toLowerCase().includes(searchTerm);
            const matchLevel = isNaN(levelFilter) || feature.level >= levelFilter;
            return matchSearch && matchLevel;
        });
        
        if (filtered.length === 0) {
            container.innerHTML = '<div class="text-center py-8 text-gray-500">Классовые настройки не найдены</div>';
            return;
        }
        
        container.innerHTML = filtered.map(feature => {
            const isSelected = currentFeatures && currentFeatures.includes(feature.name);
            return `
                <div class="border rounded-lg p-4 hover:bg-gray-50 transition">
                    <label class="flex items-start gap-3 cursor-pointer">
                        <input type="checkbox" name="features" value="${feature.name.replace(/'/g, "\\'")}" 
                               class="mt-1" ${isSelected ? 'checked' : ''}>
                        <div class="flex-1">
                            <div class="font-bold text-lg">
                                ${feature.name}
                                <span class="text-sm text-gray-500 ml-2">уровень ${feature.level}</span>
                                ${feature.level > characterLevel ? '<span class="text-xs bg-red-100 text-red-800 px-2 py-0.5 rounded ml-2">⚠️ Выше вашего уровня</span>' : ''}
                            </div>
                            <div class="text-gray-700 mt-2">${(feature.description || '').replace(/\n/g, '<br>')}</div>
                        </div>
                    </label>
                </div>
            `;
        }).join('');
    }
    
    function resetFilters() {
        document.getElementById('featureSearch').value = '';
        document.getElementById('levelFilter').value = '';
        renderFeatures();
    }
    
    document.getElementById('featureSearch').addEventListener('input', renderFeatures);
    document.getElementById('levelFilter').addEventListener('input', renderFeatures);
    
    renderFeatures();
</script>

<%- include('../partials/footer') %>