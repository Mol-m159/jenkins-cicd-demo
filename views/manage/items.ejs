<%- include('../partials/header', { user: user, title: title }) %>

<div class="bg-white rounded-lg shadow">
    <div class="p-6 border-b flex justify-between items-center flex-wrap gap-4">
        <h1 class="text-2xl font-bold">🎒 Управление предметами</h1>
        <a href="/manage/items/new" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition">
            + Новый предмет
        </a>
    </div>
    
    <div class="p-6">
        <!-- Фильтр по типам -->
        <div class="mb-4 flex gap-2 flex-wrap">
            <button class="filter-btn active px-3 py-1 rounded bg-purple-600 text-white" data-type="all">Все</button>
            <% types.forEach(type => { %>
                <button class="filter-btn px-3 py-1 rounded bg-gray-200 hover:bg-gray-300 transition" data-type="<%= type %>"><%= type %></button>
            <% }) %>
        </div>
        
        <div class="overflow-x-auto">
            <table class="w-full" id="itemsTable">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-2 text-left">Название</th>
                        <th class="px-4 py-2 text-center">Тип</th>
                        <th class="px-4 py-2 text-center">Редкость</th>
                        <th class="px-4 py-2 text-center">Вес</th>
                        <th class="px-4 py-2 text-center">Стоимость</th>
                        <th class="px-4 py-2 text-center">Аттун.</th>
                        <th class="px-4 py-2 text-center">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% items.forEach(item => { %>
                        <tr class="border-t item-row" data-type="<%= item.type %>">
                            <td class="px-4 py-3 font-medium">
                                <%= item.name %>
                                <% if (item.description && item.description.length > 50) { %>
                                    <div class="text-xs text-gray-400 truncate max-w-xs"><%= item.description.substring(0, 50) %>...</div>
                                <% } %>
                            </td>
                            <td class="px-4 py-3 text-center"><%= item.type %></td>
                            <td class="px-4 py-3 text-center">
                                <span class="px-2 py-0.5 rounded text-xs whitespace-nowrap
                                    <%= item.rarity === 'Обычный' ? 'bg-gray-200 text-gray-800' : '' %>
                                    <%= item.rarity === 'Необычный' ? 'bg-green-100 text-green-800' : '' %>
                                    <%= item.rarity === 'Редкий' ? 'bg-blue-100 text-blue-800' : '' %>
                                    <%= item.rarity === 'Очень редкий' ? 'bg-purple-100 text-purple-800' : '' %>
                                    <%= item.rarity === 'Легендарный' ? 'bg-yellow-100 text-yellow-800' : '' %>
                                    <%= item.rarity === 'Артефакт' ? 'bg-red-100 text-red-800' : '' %>">
                                    <%= item.rarity %>
                                </span>
                            </td>
                            <td class="px-4 py-3 text-center"><%= item.weight %> ф.</td>
                            <td class="px-4 py-3 text-center"><%= item.cost || '—' %></td>
                            <td class="px-4 py-3 text-center"><%= item.attunement ? '✅' : '❌' %></td>
                            <td class="px-4 py-3 text-center whitespace-nowrap">
                                <a href="/manage/items/edit/<%= encodeURIComponent(item.name) %>" class="text-blue-600 mr-2 hover:text-blue-800">✏️</a>
                                <form method="post" action="/manage/items/delete/<%= encodeURIComponent(item.name) %>" class="inline" onsubmit="return confirm('Удалить предмет «<%= item.name %>»?')">
                                    <button type="submit" class="text-red-600 hover:text-red-800">🗑️</button>
                                </form>
                             </td>
                         </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        
        <% if (items.length === 0) { %>
            <div class="text-center py-12">
                <p class="text-gray-500 mb-4">Нет предметов в библиотеке</p>
                <a href="/manage/items/new" class="text-purple-600 hover:underline">Создать первый предмет →</a>
            </div>
        <% } %>
    </div>
</div>

<script>
    document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.filter-btn').forEach(b => {
                b.classList.remove('bg-purple-600', 'text-white');
                b.classList.add('bg-gray-200');
            });
            this.classList.add('bg-purple-600', 'text-white');
            this.classList.remove('bg-gray-200');
            
            const type = this.dataset.type;
            document.querySelectorAll('.item-row').forEach(row => {
                if (type === 'all' || row.dataset.type === type) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    });
</script>

<%- include('../partials/footer') %>