<%- include('../partials/header', { user: user, title: title }) %>

<div class="bg-white rounded-lg shadow">
    <div class="p-6 border-b flex justify-between items-center flex-wrap gap-4">
        <div>
            <h1 class="text-2xl font-bold">⚙️ Классовые настройки</h1>
            <p class="text-gray-600 mt-1">
                <a href="/manage/classes" class="text-purple-600 hover:underline">← Назад к классам</a>
                / <strong><%= className %></strong>
            </p>
        </div>
        <button onclick="document.getElementById('newFeatureModal').showModal()" 
                class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">
            + Добавить настройку
        </button>
    </div>
    
    <!-- Поиск -->
    <div class="p-6 border-b bg-gray-50">
        <div class="flex gap-4">
            <div class="flex-1">
                <input type="text" id="searchInput" placeholder="Поиск по названию или описанию..."
                       class="w-full border rounded px-3 py-2">
            </div>
            <button onclick="searchFeatures()" class="bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700">
                🔍 Найти
            </button>
            <button onclick="resetSearch()" class="bg-gray-300 px-4 py-2 rounded hover:bg-gray-400">
                Сбросить
            </button>
        </div>
    </div>
    
    <div class="p-6">
        <div class="mb-4 p-3 bg-purple-50 rounded-lg">
            <p class="text-sm text-purple-800">
                💡 <strong>Классовые настройки</strong> — это особые возможности класса: 
                воззвания колдуна, инфузии изобретателя и другие уникальные механики.
            </p>
        </div>
        
        <div id="featuresCount" class="mb-3 text-sm text-gray-500"></div>
        
        <div id="featuresList" class="space-y-3">
            <% if (features && features.length > 0) { %>
                <% features.forEach(feature => { %>
                    <div class="feature-item border rounded-lg p-4 hover:shadow-md transition" 
                         data-name="<%= feature.name.toLowerCase() %>" 
                         data-description="<%= (feature.description || '').toLowerCase() %>">
                        <div class="flex justify-between items-start flex-wrap gap-4">
                            <div class="flex-1">
                                <div class="flex items-center gap-3 flex-wrap">
                                    <h3 class="text-lg font-bold text-purple-700">
                                        <%= feature.name %>
                                    </h3>
                                    <span class="text-xs bg-gray-200 px-2 py-0.5 rounded">
                                        Уровень <%= feature.level %>
                                    </span>
                                </div>
                                <div class="text-gray-700 mt-2"><%- (feature.description || '').replace(/\r\n/g, '<br>') %></div>
                            </div>
                            <div class="flex gap-2">
                                <button onclick="editFeature('<%= feature.name.replace(/'/g, "\\'") %>', '<%= feature.level %>', '<%= (feature.description || '').replace(/'/g, "\\'").replace(/\n/g, '\\n') %>')" 
                                        class="text-yellow-600 hover:text-yellow-800 px-2 py-1">✏️</button>
                                <form method="post" action="/manage/class-features/delete" 
                                      class="inline" onsubmit="return confirm('Удалить эту настройку?')">
                                    <input type="hidden" name="class_name" value="<%= className %>">
                                    <input type="hidden" name="name" value="<%= feature.name %>">
                                    <button type="submit" class="text-red-600 hover:text-red-800 px-2 py-1">🗑️</button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="text-center py-12 text-gray-500">
                    <p>Нет классовых настроек</p>
                    <p class="text-sm mt-2">Добавьте воззвания или другие особенности</p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Модальное окно добавления -->
<dialog id="newFeatureModal" class="rounded-lg shadow-xl p-0 w-full max-w-lg">
    <div class="p-6">
        <h2 class="text-xl font-bold mb-4">Добавить классовую настройку</h2>
        <form method="post" action="/manage/class-features/add">
            <input type="hidden" name="class_name" value="<%= className %>">
            
            <div class="mb-4">
                <label class="block text-gray-700 mb-2">Название *</label>
                <input type="text" name="name" required class="w-full border rounded px-3 py-2">
            </div>
            
            <div class="mb-4">
                <label class="block text-gray-700 mb-2">Уровень</label>
                <input type="number" name="level" min="1" max="20" value="1" class="w-full border rounded px-3 py-2">
                <p class="text-xs text-gray-500 mt-1">Уровень, на котором становится доступна эта настройка</p>
            </div>
            
            <div class="mb-4">
                <label class="block text-gray-700 mb-2">Описание</label>
                <textarea name="description" rows="4" class="w-full border rounded px-3 py-2" 
                          placeholder="Опишите действие этой настройки..."></textarea>
            </div>
            
            <div class="flex gap-3 justify-end">
                <button type="button" onclick="document.getElementById('newFeatureModal').close()" 
                        class="bg-gray-300 px-4 py-2 rounded">Отмена</button>
                <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Добавить</button>
            </div>
        </form>
    </div>
</dialog>

<!-- Модальное окно редактирования -->
<dialog id="editFeatureModal" class="rounded-lg shadow-xl p-0 w-full max-w-lg">
    <div class="p-6">
        <h2 class="text-xl font-bold mb-4">Редактирование настройки</h2>
        <form method="post" action="/manage/class-features/edit" id="editFeatureForm">
            <input type="hidden" name="class_name" value="<%= className %>">
            <input type="hidden" name="old_name" id="edit_old_name">
            
            <div class="mb-4">
                <label class="block text-gray-700 mb-2">Название *</label>
                <input type="text" name="name" id="edit_name" required class="w-full border rounded px-3 py-2">
            </div>
            
            <div class="mb-4">
                <label class="block text-gray-700 mb-2">Уровень</label>
                <input type="number" name="level" id="edit_level" min="1" max="20" class="w-full border rounded px-3 py-2">
            </div>
            
            <div class="mb-4">
                <label class="block text-gray-700 mb-2">Описание</label>
                <textarea name="description" id="edit_description" rows="4" class="w-full border rounded px-3 py-2"></textarea>
            </div>
            
            <div class="flex gap-3 justify-end">
                <button type="button" onclick="document.getElementById('editFeatureModal').close()" 
                        class="bg-gray-300 px-4 py-2 rounded">Отмена</button>
                <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Сохранить</button>
            </div>
        </form>
    </div>
</dialog>

<script>
    function searchFeatures() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        const items = document.querySelectorAll('.feature-item');
        let visibleCount = 0;
        
        items.forEach(item => {
            const name = item.dataset.name || '';
            const description = item.dataset.description || '';
            
            if (name.includes(searchTerm) || description.includes(searchTerm) || searchTerm === '') {
                item.style.display = '';
                visibleCount++;
            } else {
                item.style.display = 'none';
            }
        });
        
        document.getElementById('featuresCount').innerText = `Найдено: ${visibleCount}`;
    }
    
    function resetSearch() {
        document.getElementById('searchInput').value = '';
        searchFeatures();
    }
    
    function editFeature(name, level, description) {
        document.getElementById('edit_old_name').value = name;
        document.getElementById('edit_name').value = name;
        document.getElementById('edit_level').value = level;
        document.getElementById('edit_description').value = description;
        document.getElementById('editFeatureModal').showModal();
    }
    
    // Поиск при вводе
    document.getElementById('searchInput').addEventListener('keyup', function(e) {
        searchFeatures();
    });
    
    // Инициализация счетчика
    document.addEventListener('DOMContentLoaded', function() {
        searchFeatures();
    });
</script>

<%- include('../partials/footer') %>