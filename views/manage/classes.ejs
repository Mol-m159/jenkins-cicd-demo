<%- include('../partials/header', { user: user, title: title }) %>

<div class="bg-white rounded-lg shadow">
    <div class="p-6 border-b flex justify-between items-center flex-wrap gap-4">
        <h1 class="text-2xl font-bold">🎭 Управление классами</h1>
        <button onclick="document.getElementById('newClassModal').showModal()" 
                class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">
            + Новый класс
        </button>
    </div>
    
    <div class="p-6">
        <div class="grid gap-4">
            <% classes.forEach(cls => { %>
                <div class="border rounded-lg p-4 hover:shadow-md transition">
                    <div class="flex justify-between items-start flex-wrap gap-4">
                        <div class="flex-1">
                            <div class="flex items-center gap-3 flex-wrap">
                                <h2 class="text-xl font-bold text-purple-700"><%= cls.class_name %></h2>
                                <div class="flex gap-2">
                                    <% if (cls.has_class_features) { %>
                                        <span class="text-xs bg-purple-100 text-purple-800 px-2 py-0.5 rounded">⚙️ Классовые настройки</span>
                                    <% } %>
                                </div>
                            </div>
                            <div class="flex gap-4 mt-2 text-sm text-gray-500">
                                <span>🎭 Архетипов: <%= cls.archetype_count || 0 %></span>
                                <span>⚔️ Умений: <%= cls.ability_count || 0 %></span>
                            </div>
                        </div>
                        <div class="flex gap-2 flex-wrap">
                            <a href="/manage/archetypes/<%= encodeURIComponent(cls.class_name) %>" 
                               class="text-blue-600 hover:text-blue-800 px-2 py-1">🎭 Архетипы</a>
                            <a href="/manage/class-abilities/<%= encodeURIComponent(cls.class_name) %>" 
                               class="text-green-600 hover:text-green-800 px-2 py-1">⚔️ Умения</a>
                            <% if (cls.has_class_features) { %>
                                <a href="/manage/class-features/<%= encodeURIComponent(cls.class_name) %>" 
                                   class="text-purple-600 hover:text-purple-800 px-2 py-1">⚙️ Классовые настройки</a>
                            <% } %>
                            <button onclick="editClass('<%= cls.class_name %>', <%= cls.has_class_features %>)" 
                                    class="text-yellow-600 hover:text-yellow-800 px-2 py-1">✏️</button>
                            <form method="post" action="/manage/classes/delete/<%= encodeURIComponent(cls.class_name) %>" 
                                  class="inline" onsubmit="return confirm('Удалить класс?')">
                                <button type="submit" class="text-red-600 hover:text-red-800 px-2 py-1">🗑️</button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
        
        <% if (classes.length === 0) { %>
            <div class="text-center py-12 text-gray-500">
                <p>Нет классов</p>
                <p class="text-sm mt-2">Создайте первый класс</p>
            </div>
        <% } %>
    </div>
</div>

<!-- Модальное окно создания класса -->
<dialog id="newClassModal" class="rounded-lg shadow-xl p-0 w-full max-w-md">
    <div class="p-6">
        <h2 class="text-xl font-bold mb-4">Новый класс</h2>
        <form method="post" action="/manage/classes/new">
            <div class="mb-4">
                <label class="block text-gray-700 mb-2">Название *</label>
                <input type="text" name="class_name" required class="w-full border rounded px-3 py-2">
            </div>
            <div class="mb-4">
                <label class="flex items-center gap-2">
                    <input type="checkbox" name="has_class_features" value="1">
                    <span>⚙️ Использует классовые настройки (воззвания)</span>
                </label>
            </div>
            <div class="flex gap-3 justify-end">
                <button type="button" onclick="document.getElementById('newClassModal').close()" 
                        class="bg-gray-300 px-4 py-2 rounded">Отмена</button>
                <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Создать</button>
            </div>
        </form>
    </div>
</dialog>

<!-- Модальное окно редактирования класса -->
<dialog id="editClassModal" class="rounded-lg shadow-xl p-0 w-full max-w-md">
    <div class="p-6">
        <h2 class="text-xl font-bold mb-4">Редактирование класса</h2>
        <form method="post" id="editClassForm">
            <div class="mb-4">
                <label class="block text-gray-700 mb-2">Название</label>
                <input type="text" id="edit_class_name" disabled class="w-full border rounded px-3 py-2 bg-gray-100">
            </div>
            <div class="mb-4">
                <label class="flex items-center gap-2">
                    <input type="checkbox" name="has_class_features" id="edit_has_class_features" value="1">
                    <span>⚙️ Использует классовые настройки (воззвания)</span>
                </label>
            </div>
            <div class="flex gap-3 justify-end">
                <button type="button" onclick="document.getElementById('editClassModal').close()" 
                        class="bg-gray-300 px-4 py-2 rounded">Отмена</button>
                <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Сохранить</button>
            </div>
        </form>
    </div>
</dialog>

<script>
    function editClass(name, hasClassFeatures) {
        document.getElementById('edit_class_name').value = name;
        document.getElementById('edit_has_class_features').checked = hasClassFeatures === 1 || hasClassFeatures === true;
        document.getElementById('editClassForm').action = `/manage/classes/edit/${encodeURIComponent(name)}`;
        document.getElementById('editClassModal').showModal();
    }
</script>

<%- include('../partials/footer') %>