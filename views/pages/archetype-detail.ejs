<%- include('../partials/header', { user: user, title: title }) %>

<div class="bg-white rounded-lg shadow p-6 mb-6">
    <div class="flex justify-between items-start flex-wrap gap-4">
        <div>
            <div class="text-sm text-purple-600 mb-1">
                <a href="/classes/<%= encodeURIComponent(className) %>" class="hover:underline"><%= className %></a> → Архетип
            </div>
            <h1 class="text-3xl font-bold text-gray-800"><%= archetype.name %></h1>
            <% if (archetype.description) { %>
                <p class="text-gray-600 mt-2"><%= archetype.description %></p>
            <% } %>
        </div>
        <a href="/classes/<%= encodeURIComponent(className) %>" class="text-purple-600 hover:underline">← Назад к классу</a>
    </div>
</div>

<!-- Вкладки -->
<div>
    <div class="flex gap-2 border-b mb-4">
        <button class="tablinks px-4 py-2 rounded-t hover:bg-gray-100 transition" onclick="openTab(event, 'abilities')">
            ⚔️ Умения архетипа
        </button>
        <button class="tablinks px-4 py-2 rounded-t hover:bg-gray-100 transition" onclick="openTab(event, 'spells')">
            ✨ Заклинания архетипа
        </button>
    </div>
    
    <!-- Умения -->
    <div id="abilities" class="tabcontent bg-white rounded-lg shadow p-6">
        <% 
        var hasAbilities = false;
        for (var level in abilitiesByLevel) {
            if (abilitiesByLevel[level] && abilitiesByLevel[level].length > 0) {
                hasAbilities = true;
                break;
            }
        }
        %>
        <% if (hasAbilities) { %>
            <% for (var level = 1; level <= 20; level++) { %>
                <% if (abilitiesByLevel[level] && abilitiesByLevel[level].length > 0) { %>
                    <div class="mb-6">
                        <h3 class="text-lg font-semibold border-b pb-2 mb-3">Уровень <%= level %></h3>
                        <div class="space-y-3">
                            <% abilitiesByLevel[level].forEach(function(ability) { %>
                                <div class="border-l-4 border-purple-600 pl-4">
                                    <div class="font-bold"><%= ability.name %></div>
                                    <div class="text-gray-700 mt-1"><%- (ability.description || '').replace(/\r\n/g, '<br>') %></div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                <% } %>
            <% } %>
        <% } else { %>
            <p class="text-gray-500">Этот архетип не дает дополнительных умений</p>
        <% } %>
    </div>
    
    <!-- Заклинания -->
    <div id="spells" class="tabcontent bg-white rounded-lg shadow p-6" style="display: none;">
        <% 
        var hasSpells = false;
        for (var level = 0; level <= 9; level++) {
            if (spellsByLevel[level] && spellsByLevel[level].length > 0) {
                hasSpells = true;
                break;
            }
        }
        %>
        <% if (hasSpells) { %>
            <% for (var level = 0; level <= 9; level++) { %>
                <% if (spellsByLevel[level] && spellsByLevel[level].length > 0) { %>
                    <div class="mb-6">
                        <h3 class="text-lg font-semibold border-b pb-2 mb-3">
                            <%= level === 0 ? 'Заговоры (0 уровень)' : level + ' уровень' %>
                        </h3>
                        <div class="space-y-3">
                            <% spellsByLevel[level].forEach(function(spell) { %>
                                <div class="border-l-4 border-blue-600 pl-4">
                                    <div class="font-bold"><%= spell.name %></div>
                                    <div class="text-sm text-gray-500"><%= spell.school %></div>
                                    <div class="text-gray-700 mt-1"><%- (spell.description || '').replace(/\r\n/g, '<br>') %></div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                <% } %>
            <% } %>
        <% } else { %>
            <p class="text-gray-500">Этот архетип не добавляет заклинаний</p>
        <% } %>
    </div>
</div>

<script>
    function openTab(evt, tabName) {
        var i, tabcontent, tablinks;
        
        tabcontent = document.getElementsByClassName("tabcontent");
        for (i = 0; i < tabcontent.length; i++) {
            tabcontent[i].style.display = "none";
        }
        
        tablinks = document.getElementsByClassName("tablinks");
        for (i = 0; i < tablinks.length; i++) {
            tablinks[i].className = tablinks[i].className.replace(" active", "");
        }
        
        document.getElementById(tabName).style.display = "block";
        evt.currentTarget.className += " active";
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        var defaultTab = document.querySelector('.tablinks');
        if (defaultTab) defaultTab.click();
    });
</script>

<%- include('../partials/footer') %>