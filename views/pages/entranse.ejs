<%- include('../partials/header', { user: user, title: title }) %>

<div class="max-w-md mx-auto bg-white rounded-lg shadow p-8">
    <h1 class="text-2xl font-bold mb-6 text-center">Вход</h1>
    
    <form method="post" action="/entranse/check">
        <div class="mb-4">
            <label class="block text-gray-700 mb-2">Имя пользователя</label>
            <input type="text" name="username" required
                   class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-purple-600">
        </div>
        
        <button type="submit" 
                class="w-full bg-green-600 text-white py-2 rounded hover:bg-green-700 transition">
            Войти
        </button>
    </form>
    
    <p class="text-center text-gray-600 mt-4">
        Нет аккаунта? <a href="/registration" class="text-purple-600 hover:underline">Зарегистрироваться</a>
    </p>
</div>

<%- include('../partials/footer') %>